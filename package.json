  "scripts": {
    "test": "node --test"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-category-utility",
    "dsc",
    "gmdss",
    "vhf",
    "distress",
    "marine"
  ],
  "author": "Bryan Clark",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sailingnaturali/signalk-dsc.git"
  },
  "homepage": "https://github.com/sailingnaturali/signalk-dsc#readme",
  "bugs": {
    "url": "https://github.com/sailingnaturali/signalk-dsc/issues"
  },
  "signalk": {
    "displayName": "DSC",
    "screenshots": [
      "./docs/screenshots/config.png",
      "./docs/screenshots/data-table.png"
    ]
  },
  "files": [
    "index.js",
    "lib",
    "docs/screenshots/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
